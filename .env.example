# Public Notion page or hub (shown in the app footer). Safe to embed in the client.
VITE_NOTION_URL=https://www.notion.so/

# "true" loads demo data from the in-memory service on startup (good for local demos)
VITE_DEMO_DATA=true

# For GitHub Pages, match /repository-name/ (CI sets this automatically in workflows).
# VITE_BASE_PATH=/software-subscription-tracker/

# Do NOT add private Notion API tokens or any secret with the VITE_ prefix — they
# become part of the public JavaScript bundle. Use a backend and Secret Manager in cloud.
